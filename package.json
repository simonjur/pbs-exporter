{
  "name": "pbs-exporter",
  "version": "0.0.0",
  "description": "Export Proxmox Backup Server metrics for Prometheus",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "main": "src/main.ts",
  "scripts": {
    "start": "node --env-file=.env src/main.ts",
    "dev": "node --env-file=.env --watch src/main.ts",
    "lint:ts": "tsc --noEmit",
    "tests:unit": "vitest run",
    "tests:unit:coverage": "vitest run --coverage",
    "build": "tsc"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "parse-duration": "^2.1.6",
    "prom-client": "^15.1.3",
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5.9.0",
    "vitest": "^4.1.9"
  }
}
